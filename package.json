{
  "name": "madrid-for-fun-fullstack",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w @madrid-for-fun/api",
    "dev:web": "npm run dev -w @madrid-for-fun/web",
    "start:api": "npm run start -w @madrid-for-fun/api",
    "typecheck:api": "npm run typecheck -w @madrid-for-fun/api",
    "build:web": "npm run build -w @madrid-for-fun/web",
    "lint:web": "npm run lint -w @madrid-for-fun/web",
    "test": "npm run test -w @madrid-for-fun/api",
    "check": "npm run typecheck -w @madrid-for-fun/api && npm run test -w @madrid-for-fun/api && npm run build -w @madrid-for-fun/web",
    "export:glorp": "npm run export:glorp -w @madrid-for-fun/api"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "lucide-react": "^1.16.0"
  }
}
